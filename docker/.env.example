# LumenRoute Docker Deployment Configuration
# Copy to .env and customize before running: docker compose up -d

# ── Server ──
LUMENROUTE_SERVER_PORT=8080

# ── Admin ──
LUMENROUTE_ADMIN_USER=admin
LUMENROUTE_ADMIN_PASSWORD=changeme

# ── Session (leave empty to auto-generate on first boot) ──
LUMENROUTE_SESSION_SECRET=

# ── Proxy ──
LUMENROUTE_API_KEY_PREFIX=llmcp_
LUMENROUTE_PROXY_AUTH_MODE=required

# ── Health & Logs ──
LUMENROUTE_HEALTH_CHECK_INTERVAL_SECONDS=30
LUMENROUTE_REQUEST_LOG_RETENTION_DAYS=7

# ── Metrics ──
LUMENROUTE_METRICS_ENABLED=true
LUMENROUTE_METRICS_PATH=/metrics
