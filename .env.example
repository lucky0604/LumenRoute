# LumenRoute Configuration
# Copy this file to .env.local and fill in your values

# --- Server ---
LUMENROUTE_SERVER_HOST=0.0.0.0
LUMENROUTE_SERVER_PORT=8080

# --- Database ---
LUMENROUTE_DB_DRIVER=sqlite
LUMENROUTE_DB_DSN=file:data/lumenroute.db?_foreign_keys=on&_journal_mode=WAL

# --- Admin ---
LUMENROUTE_ADMIN_USER=admin
LUMENROUTE_ADMIN_PASSWORD=admin123

# --- Session ---
LUMENROUTE_SESSION_SECRET=

# --- Proxy ---
LUMENROUTE_API_KEY_PREFIX=llmcp_
LUMENROUTE_PROXY_AUTH_MODE=required

# --- Metrics ---
LUMENROUTE_METRICS_PATH=/metrics
